<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ITSupportForum</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>

            body {
                background: #18191a;
                color: white;
            }

            .navbar {
                background: #242526 !important;
                border-bottom: 1px solid #3a3b3c;
            }

            .feed-container {
                max-width: 700px;
                margin: auto;
            }

            .post-card {
                background: #242526;
                border-radius: 15px;
                overflow: hidden;
                margin-bottom: 25px;
                box-shadow: 0 0 10px rgba(0,0,0,0.3);
            }

                .post-card img {
                    width: 100%;
                    max-height: 450px;
                    object-fit: cover;
                }

            .post-body {
                padding: 20px;
            }

            .post-title {
                font-size: 24px;
                font-weight: bold;
            }

            .post-content {
                color: #d0d0d0;
            }

            .sidebar {
                background: #242526;
                min-height: 100vh;
                padding: 20px;
            }

            .btn-custom {
                border-radius: 30px;
            }

            a {
                text-decoration: none;
            }

    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark">

        <div class="container-fluid">

            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">

                IT Forum

            </a>

            <div class="navbar-nav">

                <a class="nav-link"
                   asp-controller="Home"
                   asp-action="Index">

                    Home

                </a>

                <a class="nav-link"
                   asp-controller="Posts"
                   asp-action="Create">

                    Create Post

                </a>

            </div>

            <div class="ms-auto">

                @if (User.Identity.IsAuthenticated)
                {
                    <span class="text-white me-3">
                        Hello @User.Identity.Name
                    </span>

                    <form method="post"
                          asp-area="Identity"
                          asp-page="/Account/Logout"
                          style="display:inline;">

                        <button type="submit"
                                class="btn btn-danger btn-custom">

                            Logout

                        </button>

                    </form>
                }
                else
                {
                    <a class="btn btn-primary btn-custom me-2"
                       asp-area="Identity"
                       asp-page="/Account/Login">

                        Login

                    </a>

                    <a class="btn btn-success btn-custom"
                       asp-area="Identity"
                       asp-page="/Account/Register">

                        Register

                    </a>
                }

            </div>

        </div>

    </nav>

    <div class="container-fluid mt-4">

        <div class="row">

            <!-- LEFT -->

            <div class="col-md-2">

                <div class="sidebar rounded">

                    <h5>Menu</h5>

                    <hr />

                    <p>
                        <a asp-controller="Home"
                           asp-action="Index"
                           class="text-white">

                            🏠 Home

                        </a>
                    </p>

                    <p>
                        <a asp-controller="Posts"
                           asp-action="Create"
                           class="text-white">

                            ➕ Create Post

                        </a>
                    </p>

                    <p>
                        <a asp-controller="Posts"
                           asp-action="Index"
                           class="text-white">

                            📋 All Posts

                        </a>
                    </p>

                </div>

            </div>

            <!-- FEED -->

            <div class="col-md-8">

                <div class="feed-container">

                    @RenderBody()

                </div>

            </div>

            <!-- RIGHT -->

            <div class="col-md-2">

                <div class="sidebar rounded">

                    <h5>About</h5>

                    <hr />

                    <p>
                        ASP.NET MVC Forum Project
                    </p>

                    <p>
                        build by Trần Quang Vinh and Đinh Quốc Huy
                    </p>

                </div>

            </div>

        </div>

    </div>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>